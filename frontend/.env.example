# ─── Vercel / production (Project → Settings → Environment Variables) ───────
NEXT_PUBLIC_SITE_URL=https://unisonorchestration.com
NEXT_PUBLIC_EDGE_URL=https://unison-edge-gateway.unisonorchestration.workers.dev
UNISON_EDGE_GATEWAY_URL=https://unison-edge-gateway.unisonorchestration.workers.dev

# Qdrant (live moat metrics on storefront)
QDRANT_URL=https://your-cluster.us-east4-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=

# Dashboard WebAuthn (replaces Basic Auth on /dashboard)
WEBAUTHN_SESSION_SECRET=          # min 32 chars (openssl rand -hex 32); must match worker OPS_SESSION_SECRET
WEBAUTHN_RP_ID=unisonorchestration.com
WEBAUTHN_ORIGIN=https://unisonorchestration.com
WEBAUTHN_CREDENTIALS_JSON=        # passkey store JSON (set after first Touch ID register on Vercel)
WEBAUTHN_REGISTER_SECRET=         # required to add keys when credentials already exist
ADMIN_API_SECRET=                 # edge trapped-gaps + optional session secret fallback

# Optional overrides
UNISON_MCP_URL=https://unison-mcp.fly.dev
