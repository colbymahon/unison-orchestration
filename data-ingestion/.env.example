# ──────────────────────────────────────────────────────────────────────────────
# Unison Orchestration — Environment Variables
# Copy this file to .env and fill in your real credentials.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Qdrant Cloud — https://cloud.qdrant.io
# Full cluster URL, e.g. https://abc123.us-east4-0.gcp.cloud.qdrant.io:6333
QDRANT_URL=https://your-cluster-id.cloud.qdrant.io

# Qdrant Cloud API key (from the cluster dashboard → API Keys)
QDRANT_API_KEY=your-qdrant-api-key

# Edge admin — trapped-gap discovery lane (autonomous_knowledge_agent.py)
ADMIN_API_SECRET=your_shared_bearer_token
UNISON_EDGE_GATEWAY_URL=https://unison-edge-gateway.unisonorchestration.workers.dev
