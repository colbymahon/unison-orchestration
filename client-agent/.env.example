# ──────────────────────────────────────────────────────────────────────────────
# Unison Client Agent — Environment Variables
# Copy this file to .env and fill in your real credentials.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# Base network RPC endpoint (Alchemy or Infura recommended for swarm load)
BASE_RPC_URL=https://mainnet.base.org

# ── Single-agent mode (unison_client.py) ──────────────────────────────────────
# Agent wallet private key — must hold Base ETH (gas) + USDC (payload)
# Fund with ~0.001 ETH for gas, and at least $1 USDC for ~200 paid queries
AGENT_PRIVATE_KEY=0x_your_private_key_here

# Optional: set a persistent agent identity to get its own isolated free tier
# (prevents IP-bucket collisions behind corporate NAT / shared egress)
AGENT_ID=unison-agent-v1

# ── Swarm mode (swarm_commander.py) ───────────────────────────────────────────
# BIP-39 mnemonic (12 or 24 words). swarm_commander derives N child wallets
# from this seed via BIP-44 path m/44'/60'/0'/0/{agent_index}.
# Each child wallet needs its own ETH (gas) + USDC allocation on Base.
# Minimum per agent: ~0.0001 ETH + 0.10 USDC (20 paid queries headroom).
# MASTER_MNEMONIC must be distinct from any personal/exchange wallet seed.
MASTER_MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12

# ── Shared ────────────────────────────────────────────────────────────────────
# USDC on Base (canonical contract address — do not change)
USDC_CONTRACT_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
